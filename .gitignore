# Ignore everything by default
/*

# Keep only these two folders and this ignore file
!/.gitignore
!/backend/
!/backend/**
!/landing_page/
!/landing_page/**

# Python cache/virtualenv inside allowed folders
backend/**/__pycache__/
backend/**/*.pyc
backend/**/.pytest_cache/
backend/**/.mypy_cache/
backend/**/venv/
backend/**/.venv/
backend/krishiausadh/

# Node/build artifacts inside allowed folders
landing_page/**/node_modules/
landing_page/**/.next/
landing_page/**/out/
landing_page/**/dist/
landing_page/**/coverage/
landing_page/**/*.tsbuildinfo

# Env/log files inside allowed folders
backend/**/.env
backend/**/.env.*
!backend/**/.env.example
landing_page/**/.env
landing_page/**/.env.*
!landing_page/**/.env.example
backend/**/*.log
landing_page/**/*.log

# IDE/system files
**/.vscode/
**/.idea/
**/.DS_Store
Thumbs.db
**/.git_embedded_backup/
